  | ? U+FF9E..U+FF9F ?         (* Halfwidth Katakana Voiced/Semi-Voiced Sound *)
  ;

(* --- Lo: Other Letter ----------------------------------------------------- *)
(* Ideographs, syllabaries, and other letters without case                     *)
unicode_other_letter
  = ? U+00AA ?                 (* Feminine Ordinal Indicator                   *)
  | ? U+00BA ?                 (* Masculine Ordinal Indicator                  *)
  | ? U+01BB ?                 (* Latin Letter Two with Stroke                 *)
  | ? U+01C0..U+01C3 ?         (* Latin Letters (Clicks)                      *)
