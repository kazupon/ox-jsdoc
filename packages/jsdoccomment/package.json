{
  "name": "@ox-jsdoc/jsdoccomment",
  "version": "0.0.12",
  "private": true,
  "author": {
    "name": "kazuya kawaguchi",
    "email": "kawakazu80@gmail.com"
  },
  "description": "Maintained replacement for ESLint's deprecated SourceCode#getJSDocComment along with other jsdoc utilities",
  "license": "MIT",
  "keywords": [
    "ast",
    "comment",
    "estree",
    "jsdoc",
    "parser",
    "eslint",
    "sourcecode"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./src/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs.cjs"
      }
    }
  },
  "browserslist": [
    "defaults, not op_mini all"
  ],
  "scripts": {
    "build": "rollup -c && npm run types",
    "prepublishOnly": "pnpm i && pnpm run build",
    "test": "vp test run",
    "tsc": "tsc",
    "types": "esm-d-ts gen ./src/index.js --output ./dist/index.d.ts --emitCTS"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kazupon/ox-jsdoc.git",
    "directory": "packages/jsdoccomment"
  },
  "bugs": {
    "url": "https://github.com/kazupon/ox-jsdoc/issues"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "dependencies": {
    "@types/estree": "^1.0.8",
    "@typescript-eslint/types": "^8.58.0",
    "comment-parser": "1.4.6",
    "esquery": "^1.7.0",
    "jsdoc-type-pratt-parser": "~7.2.0",
    "ox-jsdoc": "workspace:*"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@rollup/plugin-babel": "^7.0.0",
    "@vitest/coverage-v8": "4.1.4",
    "@types/esquery": "^1.5.4",
    "@types/estraverse": "^5.1.7",
    "@typescript-eslint/visitor-keys": "^8.58.0",
    "@typhonjs-build-test/esm-d-ts": "0.3.0",
    "eslint": "^9.39.2",
    "espree": "^11.2.0",
    "estraverse": "^5.3.0",
    "rollup": "^4.60.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite-plus": "catalog:"
  },
  "files": [
    "/dist",
    "/src",
    "LICENSE-MIT.txt"
  ]
}
