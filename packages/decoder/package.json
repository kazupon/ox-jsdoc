{
  "name": "@ox-jsdoc/decoder",
  "version": "0.0.4",
  "description": "Lazy JS decoder for the ox-jsdoc Binary AST format. Shared by NAPI and WASM bindings.",
  "keywords": [
    "binary-ast",
    "decoder",
    "jsdoc",
    "parser"
  ],
  "license": "MIT",
  "author": {
    "name": "kazuya kawaguchi",
    "email": "kawakazu80@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kazupon/ox-jsdoc",
    "directory": "packages/decoder"
  },
  "funding": "https://github.com/sponsors/kazupon",
  "files": [
    "src/**/*.js",
    "src/**/*.d.ts"
  ],
  "type": "module",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "test": "vp test run --config vitest.config.ts"
  },
  "devDependencies": {
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
