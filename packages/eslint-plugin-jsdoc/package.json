{
  "name": "@ox-jsdoc/eslint-plugin-jsdoc",
  "version": "0.0.0",
  "private": true,
  "description": "eslint-plugin-jsdoc fork using @ox-jsdoc/jsdoccomment.",
  "keywords": [
    "eslint",
    "jsdoc",
    "plugin"
  ],
  "homepage": "https://github.com/gajus/eslint-plugin-jsdoc#readme",
  "license": "BSD-3-Clause",
  "author": {
    "name": "kazuya kawaguchi",
    "email": "kawakazu80@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kazupon/ox-jsdoc",
    "directory": "packages/decoder"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./src/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.cjs.d.cts",
        "default": "./dist/index-cjs.cjs"
      }
    },
    "./getJsdocProcessorPlugin.js": {
      "import": {
        "types": "./dist/getJsdocProcessorPlugin.d.ts",
        "default": "./src/getJsdocProcessorPlugin.js"
      },
      "require": {
        "types": "./dist/cjs/getJsdocProcessorPlugin.d.cts",
        "default": "./dist/getJsdocProcessorPlugin.cjs"
      }
    },
    "./iterateJsdoc.js": {
      "import": {
        "types": "./dist/iterateJsdoc.d.ts",
        "default": "./src/iterateJsdoc.js"
      },
      "require": {
        "types": "./dist/cjs/iterateJsdoc.d.cts",
        "default": "./dist/iterateJsdoc.cjs"
      }
    }
  },
  "scripts": {
    "ruleTypes": "node ./src/bin/generateRuleTypes.js",
    "tsc": "tsc",
    "tsc-build": "tsc -p tsconfig-prod.json",
    "tsc-cjs": "tsc -p tsconfig-cjs.json",
    "rollup": "rollup -c",
    "build": "node ./src/bin/buildEntryFileForTS.js && rimraf ./dist && mkdir dist && pnpm run rollup && NODE_ENV=production babel ./src --out-file-extension .cjs --out-dir ./dist --copy-files --source-maps --ignore ./src/bin/*.js --no-copy-ignored && replace 'to-valid-identifier' '../to-valid-identifier.cjs' 'dist' -r --include=\"*.cjs\" && replace 'require\\(\"\\.(.*?)\\.[^.]*?\"\\)' 'require(\".$1.cjs\")' 'dist' -r --include=\"*.cjs\" && pnpm run tsc-build && pnpm run tsc-cjs",
    "check-docs": "node ./src/bin/generateDocs.js --check",
    "create-docs": "pnpm run create-options && node ./src/bin/generateDocs.js && pnpm run ruleTypes",
    "create-rule": "node ./src/bin/generateRule.js",
    "create-options": "node ./src/bin/generateOptions.js",
    "lint": "eslint",
    "lint-fix": "eslint --fix",
    "test-no-cov": "BABEL_ENV=test mocha",
    "test": "c8 pnpm run test-no-cov",
    "test-cov": "TIMING=1 c8 --reporter text pnpm run test-no-cov",
    "test-index": "pnpm run test-no-cov test/rules/index.js"
  },
  "dependencies": {
    "@es-joy/resolve.exports": "1.2.0",
    "@ox-jsdoc/jsdoccomment": "workspace:*",
    "are-docs-informative": "^0.0.2",
    "comment-parser": "1.4.6",
    "debug": "^4.4.3",
    "escape-string-regexp": "^4.0.0",
    "espree": "^11.2.0",
    "esquery": "^1.7.0",
    "html-entities": "^2.6.0",
    "jsdoc-type-pratt-parser": "~7.2.0",
    "object-deep-merge": "^2.0.0",
    "parse-imports-exports": "^0.2.4",
    "semver": "^7.7.4",
    "spdx-expression-parse": "^4.0.0",
    "to-valid-identifier": "^1.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-transform-flow-strip-types": "^7.27.1",
    "@babel/preset-env": "^7.29.2",
    "@es-joy/escodegen": "^4.2.0",
    "@es-joy/jsdoc-eslint-parser": "^0.27.0",
    "@eslint/core": "^1.1.1",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/chai": "^5.2.3",
    "@types/debug": "^4.1.13",
    "@types/esquery": "^1.5.4",
    "@types/estree": "^1.0.8",
    "@types/json-schema": "^7.0.15",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@types/semver": "^7.7.1",
    "@types/spdx-expression-parse": "^3.0.5",
    "@typescript-eslint/types": "8.58.0",
    "babel-plugin-add-module-exports": "^1.0.4",
    "babel-plugin-istanbul": "^7.0.1",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "c8": "^11.0.0",
    "camelcase": "^9.0.0",
    "chai": "^6.2.2",
    "decamelize": "^6.0.1",
    "eslint": "9.39.4",
    "eslint-config-canonical": "^47.4.2",
    "gitdown": "^4.1.1",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "json-schema": "^0.4.0",
    "json-schema-to-typescript": "^15.0.4",
    "mocha": "^11.7.5",
    "open-editor": "^6.0.0",
    "playwright": "^1.59.0",
    "replace": "^1.2.2",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "sinon": "^21.0.3",
    "ts-api-utils": "^2.5.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0"
  },
  "peerDependencies": {
    "eslint": "^7.0.0 || ^8.0.0 || ^9.0.0 || ^10.0.0"
  },
  "lint-staged": {
    "*.js": "eslint --fix"
  },
  "mocha": {
    "recursive": true,
    "reporter": "dot",
    "timeout": 12000
  },
  "c8": {
    "branches": 90,
    "check-coverage": true,
    "exclude": [
      "src/rules/checkExamples.js"
    ],
    "functions": 90,
    "include": [
      "src/"
    ],
    "instrument": false,
    "lines": 90,
    "reporter": "text-summary",
    "sourceMap": false,
    "statements": 90
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  }
}
