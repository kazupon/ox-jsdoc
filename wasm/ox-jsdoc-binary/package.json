{
  "name": "@ox-jsdoc/wasm-binary",
  "version": "0.0.9",
  "description": "High-performance JSDoc parser for the browser (WebAssembly) that returns a lazy Binary AST decoder.",
  "keywords": [
    "binary-ast",
    "jsdoc",
    "parser",
    "wasm",
    "webassembly"
  ],
  "license": "MIT",
  "author": {
    "name": "kazuya kawaguchi",
    "email": "kawakazu80@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kazupon/ox-jsdoc",
    "directory": "wasm/ox-jsdoc-binary"
  },
  "funding": "https://github.com/sponsors/kazupon",
  "files": [
    "src-js/index.js",
    "src-js/index.d.ts",
    "pkg/ox_jsdoc_binary_wasm_bg.wasm",
    "pkg/ox_jsdoc_binary_wasm_bg.wasm.d.ts",
    "pkg/ox_jsdoc_binary_wasm.d.ts",
    "pkg/ox_jsdoc_binary_wasm.js"
  ],
  "type": "module",
  "main": "src-js/index.js",
  "types": "src-js/index.d.ts",
  "exports": {
    ".": {
      "types": "./src-js/index.d.ts",
      "default": "./src-js/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "wasm-pack build --target web --out-dir pkg",
    "build:release": "wasm-pack build --target web --out-dir pkg --release",
    "test": "vp test run"
  },
  "dependencies": {
    "@ox-jsdoc/decoder": "workspace:*"
  },
  "devDependencies": {
    "vite-plus": "catalog:",
    "wasm-pack": "^0.14.0"
  }
}
