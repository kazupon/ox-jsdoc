{
  "name": "ox-jsdoc-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "cargo test && pnpm --filter ox-jsdoc test && vp test",
    "check": "cargo run -p xtask -- headers:check && cargo check && vp check",
    "fmt": "cargo fmt && vp fmt",
    "release": "bumpp \"package.json\" \"wasm/**/package.json\" --commit \"release: v%s\" --all --push --tag",
    "changelog": "gh-changelogen --repo=kazupon/ox-jsdoc",
    "bench:ox-jsdoc": "cargo bench -p ox_jsdoc_benchmark",
    "bench:ox-jsdoc:parser": "cargo bench -p ox_jsdoc_benchmark --bench parser",
    "bench:ox-jsdoc:validator": "cargo bench -p ox_jsdoc_benchmark --bench validator",
    "bench:ox-jsdoc:serializer": "cargo bench -p ox_jsdoc_benchmark --bench serializer",
    "bench:ox-jsdoc:binding": "pnpm --filter @ox-jsdoc/benchmark benchmark:ox-jsdoc",
    "bench:comment-parser": "pnpm --filter @ox-jsdoc/benchmark benchmark:comment-parser"
  },
  "devDependencies": {
    "@kazupon/eslint-plugin": "^0.7.1",
    "@kazupon/vp-config": "^0.1.0",
    "@types/node": "catalog:",
    "bumpp": "^11.0.1",
    "gh-changelogen": "^0.2.8",
    "playwright": "^1.59.1",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@10.33.0"
}
